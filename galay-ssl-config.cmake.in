@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# 查找依赖
find_dependency(OpenSSL REQUIRED)
find_dependency(galay-kernel REQUIRED)

# 包含目标文件
include("${CMAKE_CURRENT_LIST_DIR}/galay-ssl-targets.cmake")

# Ensure installed package headers win over stale global installs.
if(TARGET galay-ssl::galay-ssl)
    set_target_properties(galay-ssl::galay-ssl PROPERTIES IMPORTED_NO_SYSTEM TRUE)
endif()

if(TARGET galay-kernel::galay-kernel)
    set_target_properties(galay-kernel::galay-kernel PROPERTIES IMPORTED_NO_SYSTEM TRUE)
endif()

# 检查目标是否存在
check_required_components(galay-ssl)
